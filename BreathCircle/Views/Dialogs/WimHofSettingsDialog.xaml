<Window x:Class="BreathCircle.Views.Dialogs.WimHofSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Wim Hof 参数设置"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16" Width="320">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="140"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="50"/>
        </Grid.ColumnDefinitions>

        <!-- 轮次 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="练习轮次" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox x:Name="RoundsBox" Grid.Row="0" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,4"/>
        <TextBlock Grid.Row="0" Grid.Column="2" Text="轮" VerticalAlignment="Center" Margin="0,6"/>

        <!-- 每轮呼吸次数 -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="每轮呼吸次数" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox x:Name="BreathCountBox" Grid.Row="1" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,4"/>
        <TextBlock Grid.Row="1" Grid.Column="2" Text="次" VerticalAlignment="Center" Margin="0,6"/>

        <!-- 吸气时长 -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="每次吸气时长" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox x:Name="InhaleBox" Grid.Row="2" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,4"/>
        <TextBlock Grid.Row="2" Grid.Column="2" Text="秒" VerticalAlignment="Center" Margin="0,6"/>

        <!-- 呼气时长 -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="每次呼气时长" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox x:Name="ExhaleBox" Grid.Row="3" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,4"/>
        <TextBlock Grid.Row="3" Grid.Column="2" Text="秒" VerticalAlignment="Center" Margin="0,6"/>

        <!-- 基础屏息 -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="第1轮屏息时长" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox x:Name="BaseRetentionBox" Grid.Row="4" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,4"/>
        <TextBlock Grid.Row="4" Grid.Column="2" Text="秒" VerticalAlignment="Center" Margin="0,6"/>

        <!-- 屏息递增 -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="每轮屏息递增" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox x:Name="IncrementBox" Grid.Row="5" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,4"/>
        <TextBlock Grid.Row="5" Grid.Column="2" Text="秒/轮" VerticalAlignment="Center" Margin="0,6"/>

        <!-- 恢复屏息 -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="恢复屏息时长" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox x:Name="RecoveryBox" Grid.Row="6" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,4"/>
        <TextBlock Grid.Row="6" Grid.Column="2" Text="秒" VerticalAlignment="Center" Margin="0,6"/>

        <!-- 恢复吐气 -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="恢复吐气缓冲" VerticalAlignment="Center" Margin="0,6"/>
        <TextBox x:Name="ExhaleBufferBox" Grid.Row="7" Grid.Column="1" Width="80" HorizontalAlignment="Left" Margin="0,4"/>
        <TextBlock Grid.Row="7" Grid.Column="2" Text="秒" VerticalAlignment="Center" Margin="0,6"/>

        <!-- 按钮 -->
        <StackPanel Grid.Row="8" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="默认值" Width="70" Height="28" Margin="0,0,8,0" Click="OnDefaultsClick"/>
            <Button Content="取消" Width="60" Height="28" Margin="0,0,8,0" IsCancel="True" Click="OnCancelClick"/>
            <Button Content="保存" Width="60" Height="28" IsDefault="True" Click="OnSaveClick"
                    Background="#FFFF7043" Foreground="White" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
